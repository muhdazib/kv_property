{
  "name": "KVProperty Urban Analytics",
  "dataColors": [
    "#008C83",
    "#E85F3F",
    "#C69232",
    "#7357A6",
    "#132327",
    "#4AAE9E",
    "#F2A65A",
    "#7D8F8C"
  ],
  "background": "#F4F1EA",
  "foreground": "#132327",
  "tableAccent": "#008C83",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "color": "#132327",
      "fontSize": 14
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "color": "#132327",
      "fontSize": 12
    },
    "label": {
      "fontFace": "Segoe UI",
      "color": "#637171",
      "fontSize": 10
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "color": "#E85F3F",
      "fontSize": 30
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D8D2C7" } },
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "foreground": { "solid": { "color": "#637171" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "transparency": 20
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#132327" } },
            "backgroundColor": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "Left"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F4F1EA" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#F4F1EA" } },
            "transparency": 0
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "calloutValue": [
          {
            "fontColor": { "solid": { "color": "#E85F3F" } },
            "fontSize": 30,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#637171" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFDF8" } },
            "transparency": 0
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#132327" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#075F5A" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "areaChart": {
      "*": {
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#637171" } },
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#637171" } },
            "fontSize": 10,
            "gridlineColor": { "solid": { "color": "#E7DFD3" } }
          }
        ]
      }
    },
    "clusteredBarChart": {
      "*": {
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#132327" } },
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#637171" } },
            "gridlineColor": { "solid": { "color": "#E7DFD3" } }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "backColor": { "solid": { "color": "#E7F1ED" } },
            "fontColor": { "solid": { "color": "#132327" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColorPrimary": { "solid": { "color": "#132327" } },
            "fontColorSecondary": { "solid": { "color": "#637171" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#FBFAF6" } },
            "fontSize": 9
          }
        ]
      }
    }
  }
}
